{
  "package": {
    "productName": "Medixor",
    "version": "1.0.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": ["dmg"],
      "identifier": "com.medixor.app",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "windows": [
      {
        "title": "Medixor",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'"
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "distDir": "../.next"
  }
}

